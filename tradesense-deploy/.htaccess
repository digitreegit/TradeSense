RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# API → Passenger (path must match Vite base + /api, e.g. /quant/api)
RewriteCond %{REQUEST_URI} ^/quant/api/
RewriteRule ^quant/api/(.*)$ /api/$1 [PT,L]

# Static files
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback under /quant/
RewriteRule ^quant(/.*)?$ /quant/index.html [L]
