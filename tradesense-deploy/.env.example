# TradeSense — copy to tradesense-deploy/.env on the server
# Never commit real API keys.

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

TRADING_MODE=paper

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GOOGLE_API_KEY=
AI_PROVIDER=openai

INITIAL_CAPITAL=3000
MAX_POSITION_PERCENT=15
STOP_LOSS_PERCENT=0.3
TAKE_PROFIT_PERCENT=0.8
MAX_DAILY_TRADES=200
RISK_LEVEL=moderate
DAILY_TARGET_PERCENT=1.5
DAILY_LOSS_LIMIT_PERCENT=1.0
ACCOUNT_TYPE=cash
SCAN_INTERVAL_SECONDS=1

HOST=0.0.0.0
PORT=8000
