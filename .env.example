# TradeSense — copy to backend/.env (or repo root .env for Passenger)
# Never commit real API keys.

# Alpaca (paper trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

TRADING_MODE=paper

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini — https://ai.google.dev
GOOGLE_API_KEY=

# AI_PROVIDER: openai | gemini
AI_PROVIDER=openai

# Trading (defaults match backend/app/core/config.py)
INITIAL_CAPITAL=3000
MAX_POSITION_PERCENT=15
STOP_LOSS_PERCENT=0.3
TAKE_PROFIT_PERCENT=0.8
MAX_DAILY_TRADES=200
# RISK_LEVEL: conservative | moderate | aggressive
# aggressive is tuned as "cash-safe aggressive" (higher frequency while
# still consuming settled cash only in a cash account).
RISK_LEVEL=moderate
DAILY_TARGET_PERCENT=1.0
DAILY_LOSS_LIMIT_PERCENT=0.5
ACCOUNT_TYPE=cash
SCAN_INTERVAL_SECONDS=1

# --- Capital scale (HFT paper test) ------------------------------------
# auto | 3k | 10k | 30k
# "auto" picks based on INITIAL_CAPITAL:
#   <  $6,500 → 3k
#   < $20,000 → 10k
#   otherwise → 30k
# 10k is a cash-only bridge scale — PDT rule applies only to margin
# accounts, so cash accounts can day-trade at any size. Use 30k with
# Alpaca Algo Trader Plus + SIP + us-east-1 for realistic HFT scalping.
CAPITAL_SCALE=auto

# --- Alpaca market data streaming (WebSocket) --------------------------
# iex | sip  (sip requires Algo Trader Plus subscription)
ALPACA_DATA_FEED=iex
STREAMING_ENABLED=true
# Optional comma-separated override (else taken from active engine universe)
STREAMING_SYMBOLS=

# --- Execution quality -------------------------------------------------
# Writes a JSONL execution log per trading day with
# signal/order/fill/slippage records. Safe to keep on in production.
EXECUTION_LOG_ENABLED=true
# day | ioc — IOC is preferred at 30k scale to avoid lingering unfilled
# remainders locking settled cash.
DEFAULT_ORDER_TIF=day

HOST=0.0.0.0
PORT=8000

# --- Supabase Auth + encrypted Alpaca key storage ---
# Frontend (Vite):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Backend token verification:
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Required for HS256 access tokens (default Supabase behavior).
# Copy from Supabase Dashboard → Project Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=
# Optional: override default audience "authenticated".
# SUPABASE_JWT_AUD=authenticated
TRADESENSE_SECRET_KEY=another-long-random-string-for-fernet
# Optional: SQLite path (default: ./data/tradesense.db under project root)
# TRADESENSE_DB_PATH=/path/to/tradesense.db

# --- Email alerts (Resend) ---
# API key from https://resend.com
RESEND_API_KEY=
# Verified sender (domain or onboarding address)
RESEND_FROM_EMAIL=
# Optional fallback recipient when no per-user email is available.
RECEIVER_EMAIL=

# --- Telegram alerts (Bot API) ---
# Create a bot with @BotFather, paste token here. Users enter their chat_id in Settings.
TELEGRAM_BOT_TOKEN=
# Optional: single chat for legacy / non–signed-in engine alerts
# TELEGRAM_DEFAULT_CHAT_ID=

# --- WhatsApp alerts (Twilio) ---
# https://console.twilio.com — Sandbox or approved WhatsApp sender
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# e.g. whatsapp:+14155238886 (sandbox) or your approved WhatsApp-enabled number
TWILIO_WHATSAPP_FROM=
